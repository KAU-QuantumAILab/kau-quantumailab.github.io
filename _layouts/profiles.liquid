---
layout: page
---
<div class="post people">
  <article>
    {% if page.professor %}
      <div class="professor-profile">
        <div class="profile float-right">
          {% if page.professor.image %}
            {% assign professor_image_path = page.professor.image | prepend: 'assets/img/' %}
            {% include figure.liquid loading="eager" path=professor_image_path class="img-fluid z-depth-1 rounded" sizes="300px" alt=page.professor.name %}
          {% endif %}
        </div>
        <div class="clearfix">
          <h2>{{ page.professor.name }}</h2>
          {% if page.professor.content %}
            {% capture professor_content %}{% include_relative {{ page.professor.content }} %}{% endcapture %}
            {{ professor_content | markdownify }}
          {% else %}
            {{ content }}
          {% endif %}
        </div>
      </div>
    {% endif %}

    {% for group in page.member_groups %}
      <h2>{{ group.title }}</h2>
      <div class="people-grid">
        {% for member in group.members %}
          <div class="person-card">
            {% if member.image %}
              {% assign member_image_path = member.image | prepend: 'assets/img/' %}
              {% include figure.liquid loading="lazy" path=member_image_path class="person-photo" sizes="260px" alt=member.name %}
            {% else %}
              <div class="person-photo person-photo-placeholder"></div>
            {% endif %}
            <h3>{{ member.name }} ({{ member.korean_name }})</h3>
            {% if member.interests and member.interests.size > 0 %}
              <div class="person-interests" aria-label="{{ member.name }} research interests">
                {% for interest in member.interests %}
                  <span>{{ interest }}</span>
                {% endfor %}
              </div>
            {% endif %}
          </div>
        {% endfor %}
      </div>
    {% endfor %}
  </article>
</div>
